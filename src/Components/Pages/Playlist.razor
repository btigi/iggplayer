@page "/playlist"
@implements IDisposable
@using IggPlayer.Data
@using IggPlayer.Services
@inject PlaylistService PlaylistSvc
@inject PlayLogService PlayLog
@rendermode InteractiveServer


<div class="app-container">
    <header class="app-header">
        <h1 class="page-heading">Playlist</h1>
        <div class="header-actions">
            @if (PlaylistSvc.Queue.Count > 0)
            {
                <span class="track-count">@PlaylistSvc.Queue.Count tracks</span>
                <button class="btn btn-scan" @onclick="ClearPlaylist">Clear All</button>
            }
        </div>
    </header>

    @if (PlaylistSvc.Queue.Count == 0)
    {
        <div class="empty-state">
            <p>Your playlist is empty.</p>
            <p>Go to <a href="/" class="link">Search</a> and add some tracks.</p>
        </div>
    }
    else
    {
        <div class="track-list">
            @for (var i = 0; i < PlaylistSvc.Queue.Count; i++)
            {
                var index = i;
                var track = PlaylistSvc.Queue[i];
                var isCurrent = i == PlaylistSvc.CurrentIndex;

                <div class="track-item @(isCurrent ? "active" : "")">
                    <button class="track-play-btn" @onclick="() => JumpTo(index, track)" title="Play this track">
                        <div class="track-play-icon">
                            @if (isCurrent)
                            {
                                <svg viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
                            }
                            else
                            {
                                <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>
                            }
                        </div>
                    </button>
                    <span class="playlist-index">@(index + 1)</span>
                    <div class="track-info">
                        <span class="track-title">@(track.Title ?? track.FileName)</span>
                        <span class="track-meta">
                            @if (!string.IsNullOrEmpty(track.Artist))
                            {
                                <span>@track.Artist</span>
                            }
                            @if (!string.IsNullOrEmpty(track.Album))
                            {
                                <span class="separator">·</span>
                                <span>@track.Album</span>
                            }
                        </span>
                    </div>
                    <span class="track-duration">@FormatDuration(track.Duration)</span>
                    <button class="track-remove-btn" @onclick="() => Remove(index)" title="Remove from playlist">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                            <path d="M18 6 6 18M6 6l12 12"/>
                        </svg>
                    </button>
                </div>
            }
        </div>
    }
</div>

@code {
    protected override void OnInitialized()
    {
        PlaylistSvc.OnChanged += OnPlaylistChanged;
    }

    private async Task JumpTo(int index, Track track)
    {
        PlaylistSvc.JumpTo(index);
        await PlayLog.LogPlayAsync(track);
    }

    private void Remove(int index)
    {
        PlaylistSvc.RemoveAt(index);
    }

    private void ClearPlaylist()
    {
        PlaylistSvc.Clear();
    }

    private static string FormatDuration(TimeSpan ts)
    {
        return ts.TotalHours >= 1
            ? ts.ToString(@"h\:mm\:ss")
            : ts.ToString(@"m\:ss");
    }

    private void OnPlaylistChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        PlaylistSvc.OnChanged -= OnPlaylistChanged;
    }
}